# ── Environment / secrets (NEVER commit these) ───────────────────────────────
.env
.env.local
.env.*.local
server/.env
agents/.env

# Allow example/template env files (no real secrets)
!*.env.example
!.env.otx.example

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
server/node_modules/
agents/node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
dist-ssr/
server/dist/
.vite/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Claude Code local settings (may contain secrets) ─────────────────────────
.claude/

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS ────────────────────────────────────────────────────────────────────────
Thumbs.db
