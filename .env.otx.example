# OTXEngine — Environment variables
# Copy to .env.local (frontend) and agents/.env (Deno agents)

# ── Supabase ──────────────────────────────────────────────────────────────────
 # agents only — never expose in frontend
VITE_SUPABASE_URL=https://your-project.supabase.co     # frontend (anon key)
VITE_SUPABASE_ANON_KEY=your_anon_key_here              # frontend (anon key)

# ── OpenAI (ProfileIntelligence agent) ───────────────────────────────────────
OPENAI_API_KEY=sk-proj-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_key_here

TAVILY_API_KEY=tvly-dev-your_tavily_key_here
APIFY_API_KEY=apify_api_your_apify_key_here
SERPAPI_API_KEY=your_serpapi_key_here

GOOGLE_PLACES_API_KEY=your_google_places_key_here
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here


# ── Eventbrite (EventCollector) ───────────────────────────────────────────────
EVENTBRITE_API_KEY=your_eventbrite_key_here

# ── Google Places (CompetitorSnapshot) ───────────────────────────────────────


# ── Agent thresholds (optional — defaults shown) ──────────────────────────────
INTENT_THRESHOLD=0.65        # IntentClassification: min intent_score to qualify signal
Z_THRESHOLD=2.0              # SectorTrendRadar: min Z-score for spike detection
ACTION_THRESHOLD=0.60        # ActionScoringService: min action_score to write recommendation

# ── SystemHealthMonitor ───────────────────────────────────────────────────────
HEALTH_PORT=8080
