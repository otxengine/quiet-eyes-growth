// ── Meta Integration ──────────────────────────────────────────────────────────

/**
 * One MetaConnection per connected WhatsApp phone or Facebook Page.
 * Linked to a BusinessProfile (our "tenant"). Tokens are always encrypted.
 */
model MetaConnection {
  id                  String   @id @default(cuid())
  created_date        DateTime @default(now())
  business_profile_id String                        // FK → BusinessProfile.id
  platform            String                        // 'whatsapp' | 'messenger'
  page_id             String?  @unique              // Facebook Page ID (Messenger)
  phone_number_id     String?  @unique              // WhatsApp Cloud API Phone Number ID
  waba_id             String?                       // WhatsApp Business Account ID
  encrypted_token     String                        // AES-256-GCM; never plaintext
  is_active           Boolean  @default(true)
  token_expires_at    String?                       // ISO string; long-lived tokens ~60 days

  agentConfigs  AIAgentConfig[]
  conversations Conversation[]

  @@map("meta_connections")
}

/**
 * AI agent configuration bound to a specific MetaConnection.
 * Each connection can have one active agent (lead_gen, trend_analysis, etc.)
 */
model AIAgentConfig {
  id                 String   @id @default(cuid())
  created_date       DateTime @default(now())
  meta_connection_id String
  agent_type         String                        // 'lead_gen' | 'trend_analysis' | 'competitor_monitor' | 'campaign'
  system_prompt      String                        // Full system prompt injected before every LLM call
  is_active          Boolean  @default(true)
  max_tokens         Int      @default(500)
  temperature        Float    @default(0.7)
  handoff_keywords   String?                       // Comma-separated; triggers human escalation

  metaConnection MetaConnection @relation(fields: [meta_connection_id], references: [id], onDelete: Cascade)

  @@map("ai_agent_configs")
}

/**
 * Persists conversation history per sender so the AI has context across messages.
 * Also tracks human-handoff state to suppress AI responses after escalation.
 */
model Conversation {
  id                 String   @id @default(cuid())
  created_date       DateTime @default(now())
  meta_connection_id String
  sender_id          String                        // WhatsApp phone number or Messenger PSID
  platform           String                        // 'whatsapp' | 'messenger'
  status             String   @default("active")   // 'active' | 'human_handoff' | 'closed'
  context            String?                       // JSON array of {role, content} — last 20 turns
  last_message_at    String?
  handoff_reason     String?

  metaConnection MetaConnection @relation(fields: [meta_connection_id], references: [id], onDelete: Cascade)

  @@unique([meta_connection_id, sender_id])
  @@map("conversations")
}

