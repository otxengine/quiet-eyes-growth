  hot_lead_alerts            Boolean? @default(true)
  monthly_summary            Boolean? @default(false)
  push_email_alerts          Boolean? @default(false)
  push_whatsapp_alerts       Boolean? @default(false)
  push_whatsapp_number       String?
  push_min_score             Float?   @default(80)
  bot_enabled                Boolean? @default(false)
  bot_greeting               String?
  bot_qualification_questions String?
  bot_good_lead_criteria     String?
  bot_bad_lead_criteria      String?
  bot_services_info          String?
  channels_whatsapp          String?
  channels_whatsapp_enabled  Boolean? @default(false)
  channels_instagram         String?
  channels_instagram_enabled Boolean? @default(false)
  channels_facebook          String?
  channels_facebook_enabled  Boolean? @default(false)
  channels_tiktok            String?
  channels_tiktok_enabled    Boolean? @default(false)
  channels_website           String?
  channels_website_enabled   Boolean? @default(false)
  channels_webhook_secret    String?
  website_url                String?
  facebook_url               String?
  instagram_url              String?
  tiktok_url                 String?
  custom_keywords            String?
  custom_urls                String?
  monitor_competitors_social Boolean? @default(true)
  onboarding_completed       Boolean? @default(false)
  plan_id                    String?  @default("free")
  subscription_status        String?  @default("none")
  stripe_customer_id         String?
  subscription_started_at    String?
  auto_respond_enabled       Boolean? @default(false)
  auto_respond_min_rating    Float?   @default(5)
  auto_respond_notify        Boolean? @default(true)
  wa_alert_phone             String?
  wa_alert_negative_review   Boolean? @default(true)
  wa_alert_hot_lead          Boolean? @default(true)
  wa_alert_high_impact       Boolean? @default(false)
  crm_webhook_url            String?
  crm_webhook_enabled        Boolean? @default(false)
  crm_sync_events            String?  @default("create,update")
  crm_zapier_url             String?
  crm_zapier_enabled         Boolean? @default(false)
  crm_last_sync              String?
  crm_sync_count             Float?   @default(0)
  crm_hubspot_api_key        String?
  crm_hubspot_enabled        Boolean? @default(false)
  crm_hubspot_pipeline_id    String?
  crm_hubspot_field_map      String?
  crm_monday_api_key         String?
  crm_monday_enabled         Boolean? @default(false)
  crm_monday_board_id        String?
  crm_monday_field_map       String?
  survey_enabled             Boolean? @default(false)
  survey_q1                  String?
  survey_q2                  String?
  survey_q3                  String?
  locations_prompt_dismissed Boolean? @default(false)
  created_at                 String?
  google_place_id            String?
  google_place_id_verified   Boolean? @default(false)
  google_rating              Float?
  google_review_count        Float?
  // Autonomy + API execution
  autonomy_level             String?  @default("semi_auto") // 'manual' | 'semi_auto' | 'full_auto'
  whatsapp_phone_number_id   String?  // Meta WhatsApp Cloud API phone number ID
  whatsapp_access_token      String?  // encrypted Meta system user token
  google_access_token        String?  // Google Business Profile OAuth token
  instagram_access_token     String?  // Instagram Graph API token
  instagram_page_id          String?  // Instagram Business account ID
