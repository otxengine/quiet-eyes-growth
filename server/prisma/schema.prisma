model Lead {
  id                  String   @id @default(cuid())
  created_date        DateTime @default(now())
  created_by          String?
  linked_business     String?
  linked_location     String?
  name                String
  source              String?
  score               Float?
  status              String?
  budget_range        String?
  service_needed      String?
  contact_info        String?
  contact_phone       String?
  questionnaire_answers String?
  city                String?
  urgency             String?
  intent_source       String?
  intent_strength     String?
  created_at          String?
  lifecycle_stage     String?  @default("new")
  lifecycle_updated_at String?
  notes               String?
  next_action         String?
  next_action_date    String?
  total_value         Float?
  tags                String?
  source_url          String?
  source_description  String?
  discovery_method    String?
  closed_value        Float?
  closed_at           String?
  source_agent        String?
  source_origin       String?  @default("manual")
  // P1: Intent Freshness Score
  discovered_at       String?
  freshness_score     Float?   @default(100)
  last_contact_at     String?
  next_followup_date  String?
  followup_count      Float?   @default(0)
