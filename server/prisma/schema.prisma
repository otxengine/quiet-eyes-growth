  created_date               DateTime @default(now())
  created_by                 String?
  name                       String
  category                   String
  city                       String
  full_address               String?
  tone_preference            String?  @default("friendly")
  target_market              String?
  description                String?
  min_budget                 String?
  relevant_services          String?
  preferred_area             String?
