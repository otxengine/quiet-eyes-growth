/**
 * AutoAction — tracks every autonomous action taken (or pending approval)
 * by the agent pipeline. Powers the Dashboard ROI feed + approval inbox.
 *
 * status flow:
 *   pending_approval → approved → completed | failed | rejected
 *   (semi_auto also sets auto_execute_at for delayed auto-execution)
 *   full_auto goes straight to completed
 */
model AutoAction {
  id               String   @id @default(cuid())
  created_date     DateTime @default(now())
  linked_business  String
  agent_name       String   // which agent created this action
  action_type      String   // 'review_reply' | 'whatsapp_send' | 'post_publish' | 'review_request'
  description      String   // human-readable: "תגובה לביקורת של משה כהן (2⭐)"
  payload          String?  // JSON — action-specific data (review_id, message, phone, etc.)
  result           String?  // execution result message
  status           String   @default("pending_approval") // 'pending_approval'|'approved'|'executing'|'completed'|'failed'|'rejected'
  executed_at      String?
  revenue_impact   Float?   @default(0) // estimated ₪ impact
  auto_execute_at  String?  // semi_auto: ISO timestamp for auto-execution if not acted on

  @@map("auto_actions")
}
