    "battlecard_updated_at": {
      "type": "string",
      "description": "\u05ea\u05d0\u05e8\u05d9\u05da \u05e2\u05d3\u05db\u05d5\u05df \u05db\u05e8\u05d8\u05d9\u05e1 \u05e7\u05e8\u05d1"
    },
    "linked_location": {
      "type": "string",
      "description": "\u05de\u05d6\u05d4\u05d4 \u05e1\u05e0\u05d9\u05e3 \u05de\u05e7\u05d5\u05e9\u05e8"
    },
    "source_urls": {
      "type": "string",
      "description": "\u05db\u05ea\u05d5\u05d1\u05d5\u05ea URL \u05de\u05e7\u05d5\u05e8 \u05de\u05d5\u05e4\u05e8\u05d3\u05d5\u05ea \u05d1-|"
    },
