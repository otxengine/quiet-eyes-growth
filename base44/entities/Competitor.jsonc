      "default": "\u05dc\u05d0 \u05de\u05d0\u05d5\u05de\u05ea",
      "description": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05d0\u05d9\u05de\u05d5\u05ea"
    },
    "menu_highlights": {
      "type": "string",
      "description": "\u05de\u05d5\u05e6\u05e8\u05d9\u05dd/\u05e9\u05d9\u05e8\u05d5\u05ea\u05d9\u05dd \u05e2\u05d9\u05e7\u05e8\u05d9\u05d9\u05dd \u05e9\u05e0\u05de\u05e6\u05d0\u05d5"
    },
    "price_points": {
      "type": "string",
      "description": "\u05de\u05d7\u05d9\u05e8\u05d9\u05dd \u05e1\u05e4\u05e6\u05d9\u05e4\u05d9\u05d9\u05dd \u05e9\u05e0\u05de\u05e6\u05d0\u05d5"
